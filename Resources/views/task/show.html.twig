{% extends 'base.html.twig' %}
{% import "macros/widgets.html.twig" as widgets %}

{% block page_title %}{{ task.title }}{% endblock %}

{% block main %}
    <div class="d-flex justify-content-end mb-3">
        <div class="btn-list">
            {% if activeTimesheet %}
                <form action="{{ path('task_stop_timer', {id: task.id}) }}" method="post" class="d-inline">
                    <button type="submit" class="btn btn-danger">
                        {{ icon('stop', true) }} {{ 'stop'|trans }}
                    </button>
                </form>
            {% else %}
                <form action="{{ path('task_start_timer', {id: task.id}) }}" method="post" class="d-inline">
                    <button type="submit" class="btn btn-success">
                        {{ icon('start', true) }} {{ 'start'|trans }}
                    </button>
                </form>
            {% endif %}
            <a href="{{ path('task_edit', {id: task.id}) }}" class="btn">
                {{ icon('edit', true) }} {{ 'edit'|trans }}
            </a>
            <a href="{{ path('task_index') }}" class="btn">
                {{ icon('back', true) }} {{ 'back'|trans }}
            </a>
        </div>
    </div>
<div class="row">
    <div class="col-lg-8">
        {# Task Details Card #}
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title">
                    {{ task.title }}
                    {% if task.internal %}
                        <span class="badge bg-secondary-lt ms-2">{{ 'Internal'|trans }}</span>
                    {% endif %}
                </h3>
            </div>
            <div class="card-body">
                <div class="datagrid">
                    <div class="datagrid-item">
                        <div class="datagrid-title">{{ 'Project'|trans }}</div>
                        <div class="datagrid-content">
                            {{ widgets.label_color(task.project.name, task.project.color|colorize(task.project.name)) }}
                        </div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">{{ 'Customer'|trans }}</div>
                        <div class="datagrid-content">
                            {{ widgets.label_color(task.project.customer.name, task.project.customer.color|colorize(task.project.customer.name)) }}
                        </div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">{{ 'Status'|trans }}</div>
                        <div class="datagrid-content">
                            <span class="badge" style="background-color: {{ task.status.color }}; color: {{ task.status.color|font_contrast }}">
                                {{ task.status.label }}
                            </span>
                        </div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">{{ 'Priority'|trans }}</div>
                        <div class="datagrid-content">
                            <span class="badge" style="background-color: {{ task.priority.color }}; color: {{ task.priority.color|font_contrast }}">
                                {{ task.priority.label }}
                            </span>
                        </div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">{{ 'Assignee'|trans }}</div>
                        <div class="datagrid-content">
                            {% if task.assignee %}
                                {{ widgets.user_avatar(task.assignee, false, 'avatar-sm') }}
                                {{ task.assignee.displayName }}
                            {% else %}
                                <span class="text-muted">{{ 'Unassigned'|trans }}</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">{{ 'Due Date'|trans }}</div>
                        <div class="datagrid-content">
                            {% if task.dueDate %}
                                {{ task.dueDate|date_short }}
                                {% if task.overdue %}
                                    <span class="badge bg-danger ms-1">{{ 'Overdue'|trans }}</span>
                                {% endif %}
                            {% else %}
                                <span class="text-muted">&ndash;</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">{{ 'Estimated Time'|trans }}</div>
                        <div class="datagrid-content">
                            {% if task.estimatedMinutes %}
                                {{ (task.estimatedMinutes * 60)|duration }}
                            {% else %}
                                <span class="text-muted">&ndash;</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">{{ 'Created'|trans }}</div>
                        <div class="datagrid-content">
                            {{ task.createdAt|date_full }}
                            <small class="text-muted d-block">{{ 'by'|trans }} {{ task.createdBy.displayName }}</small>
                        </div>
                    </div>
                </div>

                {% if task.description %}
                <div class="mt-4">
                    <h4>{{ 'Description'|trans }}</h4>
                    <div class="markdown">
                        {{ task.description|md2html }}
                    </div>
                </div>
                {% endif %}
            </div>
        </div>

        {# Recurrence Info #}
        {% if task.recurrence %}
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title">{{ icon('repeat') }} {{ 'Recurring Task'|trans }}</h3>
            </div>
            <div class="card-body">
                <div class="datagrid">
                    <div class="datagrid-item">
                        <div class="datagrid-title">{{ 'Frequency'|trans }}</div>
                        <div class="datagrid-content">
                            {{ ('Every'|trans) }} {{ task.recurrence.interval }} {{ task.recurrence.frequency|trans }}
                        </div>
                    </div>
                    <div class="datagrid-item">
                        <div class="datagrid-title">{{ 'Next run'|trans }}</div>
                        <div class="datagrid-content">
                            {{ task.recurrence.nextRunDate|date_short }}
                        </div>
                    </div>
                    {% if task.recurrence.endDate %}
                    <div class="datagrid-item">
                        <div class="datagrid-title">{{ 'End Date'|trans }}</div>
                        <div class="datagrid-content">
                            {{ task.recurrence.endDate|date_short }}
                        </div>
                    </div>
                    {% endif %}
                    <div class="datagrid-item">
                        <div class="datagrid-title">{{ 'Tasks created'|trans }}</div>
                        <div class="datagrid-content">
                            {{ task.recurrence.createdTasks }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# Dependencies #}
        {% include '@Task/task/_dependencies.html.twig' %}

        {# Subtasks #}
        {% include '@Task/task/_subtasks.html.twig' %}

        {# Attachments #}
        {% include '@Task/task/_attachments.html.twig' %}

        {# Comments #}
        {% include '@Task/task/_comments.html.twig' %}

        {# History #}
        {% include '@Task/task/_history.html.twig' %}

        {# Timesheet History #}
        {% if timesheets|length > 0 %}
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">{{ 'Time Entries'|trans }}</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-striped card-table">
                    <thead>
                        <tr>
                            <th>{{ 'User'|trans }}</th>
                            <th>{{ 'Date'|trans }}</th>
                            <th>{{ 'Start'|trans }}</th>
                            <th>{{ 'End'|trans }}</th>
                            <th class="text-end">{{ 'Duration'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for timesheet in timesheets %}
                        <tr>
                            <td>
                                {{ widgets.user_avatar(timesheet.user, false, 'avatar-sm') }}
                                {{ timesheet.user.displayName }}
                            </td>
                            <td>{{ timesheet.begin|date_short }}</td>
                            <td>{{ timesheet.begin|time }}</td>
                            <td>
                                {% if timesheet.end %}
                                    {{ timesheet.end|time }}
                                {% else %}
                                    <span class="badge bg-success">{{ 'Running'|trans }}</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                {% if timesheet.duration %}
                                    {{ timesheet.duration|duration }}
                                {% else %}
                                    &ndash;
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}
    </div>

    <div class="col-lg-4">
        {# Time Tracking Card #}
        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title">{{ 'Time Tracking'|trans }}</h3>
            </div>
            <div class="card-body text-center">
                <div class="display-6 fw-bold text-primary mb-1">
                    {{ totalDurationFormatted }}
                </div>
                <div class="text-muted small">{{ 'Total time spent'|trans }}</div>

                {% if task.estimatedMinutes %}
                <div class="mt-3">
                    {% set percentage = (totalDuration / (task.estimatedMinutes * 60)) * 100 %}
                    {% set barColor = percentage > 100 ? 'bg-danger' : (percentage > 80 ? 'bg-warning' : 'bg-primary') %}
                    <div class="progress mb-2" style="height: 8px;">
                        <div class="progress-bar {{ barColor }}" style="width: {{ percentage > 100 ? 100 : percentage }}%"></div>
                    </div>
                    <small class="text-muted">
                        {{ percentage|number_format(0) }}% {{ 'of estimated'|trans }} {{ (task.estimatedMinutes * 60)|duration }}
                    </small>
                </div>
                {% endif %}

                {% if activeTimesheet %}
                <div class="alert alert-success mt-3 mb-0">
                    {{ icon('play') }}
                    {{ 'Timer running since'|trans }} {{ activeTimesheet.begin|time }}
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
